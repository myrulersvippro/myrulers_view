server {{
    listen 80;
    server_name _;
    return 301 https://$host$request_uri;
}}


server {
    set $php_sock unix:/run/php/php8.3-fpm.sock;

    listen 443 ssl;
    server_name binh-chon.vn;

    root /var/www/public;

    index index.php index.html;

    ssl_certificate     /var/www/ssl/binh-chon.vn/cert.crt;
    ssl_certificate_key /var/www/ssl/binh-chon.vn/prv.key;

    include snippets/common.conf;
}


